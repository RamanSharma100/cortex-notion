{
  "name": "cortex-notion",
  "version": "1.1.0",
  "description": "An AI-powered Notion CLI agent for project planning and market research.",
  "main": "dist/index.js",
  "bin": {
    "cortex": "bin/cortex.js"
  },
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --clean --minify",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint 'src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "prepublishOnly": "pnpm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "keywords": [
    "notion",
    "ai",
    "cli",
    "startup",
    "planner",
    "gpt-4"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "openai": "^6.32.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
